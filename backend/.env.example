# Database
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/ai_media

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Midjourney (ImagineAPI-like wrapper)
MIDJOURNEY_API_URL=https://api.imaginepro.ai
